{
  "compilerOptions": {
    "target": "ES2017",
    "module": "None",
    "lib": ["ES2017", "DOM", "DOM.Iterable"],
    "strict": true,
    "outDir": "src/scripts",
    "rootDir": "src/scripts",
    "removeComments": false,
    "noEmitOnError": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src/scripts/**/*.ts"],
  "exclude": ["node_modules"]
}
